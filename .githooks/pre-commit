#!/bin/sh

# Check for console.log in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FILES_WITH_LOGS=$(echo "$STAGED_FILES" | xargs grep -l "console\.log" 2>/dev/null)

if [ -z "$FILES_WITH_LOGS" ]; then
  exit 0
fi

echo ""
echo "❌ Se encontraron console.log en los siguientes archivos:"
echo "$FILES_WITH_LOGS" | while read -r file; do
  grep -n "console\.log" "$file" | while read -r match; do
    echo "   $file:$match"
  done
done

echo ""
printf "¿Querés eliminarlos automáticamente? (s/N): "
read -r ANSWER < /dev/tty

if [ "$ANSWER" = "s" ] || [ "$ANSWER" = "S" ]; then
  echo "$FILES_WITH_LOGS" | while read -r file; do
    sed -i '/console\.log/d' "$file"
    git add "$file"
  done
  echo "✅ console.log eliminados y archivos re-staged. Continuando con el commit..."
  exit 0
else
  echo "⛔ Commit cancelado. Eliminá los console.log manualmente antes de commitear."
  exit 1
fi
