#!/bin/sh

# Check for console.log in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FILES_WITH_LOGS=$(echo "$STAGED_FILES" | xargs grep -l "console\.log" 2>/dev/null)

if [ -z "$FILES_WITH_LOGS" ]; then
  exit 0
fi

echo ""
echo "❌ console.log statements found in the following files:"
echo "$FILES_WITH_LOGS" | while read -r file; do
  grep -n "console\.log" "$file" | while read -r match; do
    echo "   $file:$match"
  done
done

echo ""
printf "Remove them automatically? (y/N): "
read -r ANSWER < /dev/tty

if [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ]; then
  echo "$FILES_WITH_LOGS" | while read -r file; do
    sed -i '/console\.log/d' "$file"
    git add "$file"
  done
  echo "✅ console.log removed and files re-staged. Continuing with commit..."
  exit 0
else
  echo "⛔ Commit cancelled. Remove the console.log statements manually before committing."
  exit 1
fi
