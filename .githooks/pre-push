#!/bin/sh

# Validate branch naming convention before pushing

BRANCH=$(git rev-parse --abbrev-ref HEAD)

ALLOWED_PATTERN="^(main|staging|develop|feature/.+|fix/.+|hotfix/.+|chore/.+|docs/.+|refactor/.+)$"

if echo "$BRANCH" | grep -qE "$ALLOWED_PATTERN"; then
  exit 0
fi

echo ""
echo "❌ Branch name '$BRANCH' does not follow the naming convention."
echo ""
echo "   Allowed prefixes:"
echo "     feature/<name>   → new functionality"
echo "     fix/<name>       → bug fix"
echo "     hotfix/<name>    → urgent production fix"
echo "     chore/<name>     → maintenance tasks"
echo "     docs/<name>      → documentation"
echo "     refactor/<name>  → refactoring"
echo ""
echo "   Base branches: main, staging, develop"
echo ""
echo "⛔ Push cancelled. To fix it:"
echo ""
echo "   1. Rename the local branch:"
echo "      git branch -m $BRANCH feature/<new-name>"
echo ""
echo "   2. If already pushed to remote, delete it there and push the renamed one:"
echo "      git push origin --delete $BRANCH"
echo "      git push -u origin feature/<new-name>"
echo ""
exit 1
